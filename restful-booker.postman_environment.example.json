{
  "id": "restful-booker-env",
  "name": "Restful-Booker",
  "values": [
    {
      "key": "base_url",
      "value": "https://restful-booker.herokuapp.com",
      "type": "default",
      "enabled": true
    },
    {
      "key": "username",
      "value": "YOUR_USERNAME",
      "type": "default",
      "enabled": true
    },
    {
      "key": "password",
      "value": "YOUR_PASSWORD",
      "type": "secret",
      "enabled": true
    },
    {
      "key": "token",
      "value": "",
      "type": "default",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment"
}
